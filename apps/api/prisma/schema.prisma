generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum LeadPipelineStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
  CLOSED
}

enum ConversationThreadStatus {
  OPEN
  ACTIVE
  ARCHIVED
  CLOSED
}

enum ConversationSource {
  WIDGET
  API
  DASHBOARD
}

enum UserRole {
  user
  admin
  root
}

// --- Core identity & tenancy ---

model User {
  id        String    @id @default(uuid()) @db.Uuid
  email     String    @unique
  role      UserRole  @default(user)
  passwordHash          String?   @map("password_hash")
  passwordResetToken    String?   @unique @map("password_reset_token")
  passwordResetExpires  DateTime? @map("password_reset_expires")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  memberships              Membership[]
  usages                     Usage[]
  initiatedAgentExecutions   AgentExecution[] @relation("ExecutionInitiator")
  leadStatusChanges          LeadStatusHistory[]
  conversationsCreated       Conversation[]   @relation("ConversationCreatedBy")
  adminAuditLogs             AdminAuditLog[] @relation("AdminAuditActor")

  @@map("users")
}

model AdminAuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  adminId   String   @map("admin_id") @db.Uuid
  admin     User     @relation("AdminAuditActor", fields: [adminId], references: [id], onDelete: Restrict)
  action    String
  entity    String
  entityId  String   @map("entity_id") @db.Uuid
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model Plan {
  id                  String    @id @default(uuid()) @db.Uuid
  slug                String
  name                String
  maxRequestsPerMonth Int?      @map("max_requests_per_month")
  maxTokensPerMonth   Int?      @map("max_tokens_per_month")
  allowedModels       Json      @map("allowed_models")
  /// Cost in USD per 1 000 tokens. null = free / metered elsewhere.
  costPer1kTokens     Decimal?  @map("cost_per_1k_tokens") @db.Decimal(12, 6)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  organizations Organization[]

  @@index([slug])
  @@map("plans")
}

model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  planId    String    @map("plan_id") @db.Uuid
  plan      Plan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  requestsUsed Int    @default(0) @map("requests_used")
  tokensUsed   Int    @default(0) @map("tokens_used")
  resetAt      DateTime @map("reset_at")
  isBlocked    Boolean  @default(false) @map("is_blocked")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  memberships       Membership[]
  apiKeys           ApiKey[]
  assistants        Assistant[]
  agents            Agent[]
  tools             Tool[]
  leads             Lead[]
  leadStatusHistory LeadStatusHistory[]
  conversations     Conversation[]
  messages          Message[]
  agentExecutions   AgentExecution[]
  agentSteps        AgentStep[]
  knowledge         Knowledge[]
  knowledgeChunks   KnowledgeChunk[]
  usages            Usage[]

  @@index([planId])
  @@map("organizations")
}

model Membership {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String           @map("organization_id") @db.Uuid
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           MembershipRole
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("memberships")
}

model ApiKey {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assistantId    String?   @map("assistant_id") @db.Uuid
  assistant      Assistant? @relation(fields: [assistantId], references: [id], onDelete: SetNull)
  keyHash        String    @unique @map("key_hash")
  name           String?
  /// Allowed origin hostnames (e.g. ["example.com","*.app.example.com"]). Empty = no restriction.
  allowedDomains String[]  @map("allowed_domains")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  usages Usage[]

  @@index([organizationId])
  @@index([assistantId])
  @@map("api_keys")
}

// --- AI resources (org-scoped) ---

model Assistant {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  model          String
  systemPrompt   String    @map("system_prompt") @db.Text
  settings       Json?
  /// Per-assistant overrides: intents, funnel, memory, validation. Falls back to defaultAssistantConfig if null.
  config         Json?
  /// Bumped on breaking prompt/model/RAG changes; conversations may record which version they started under.
  version        Int       @default(1)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  knowledges    Knowledge[]
  conversations Conversation[]
  agents        Agent[]
  apiKeys       ApiKey[]
  usages        Usage[]

  @@index([organizationId])
  @@map("assistants")
}

model Agent {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assistantId    String?   @map("assistant_id") @db.Uuid
  assistant      Assistant? @relation(fields: [assistantId], references: [id], onDelete: SetNull)
  name           String
  type           String
  mode           String    @default("v1") @map("mode")
  trigger        String?
  flow           Json?
  memory         Json?
  rules          String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  tools       Tool[]
  executions  AgentExecution[]
  conversations Conversation[]

  @@index([organizationId])
  @@index([assistantId])
  @@map("agents")
}

model Tool {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentId        String    @map("agent_id") @db.Uuid
  agent          Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  /// Stable handle per agent for planner, UI, and audits (unique with agentId).
  name           String    @default(cuid())
  type           String
  config         Json
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  @@unique([agentId, name])
  @@index([organizationId])
  @@index([agentId])
  @@map("tools")
}

// --- CRM ---

model Lead {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  source         String
  status         LeadPipelineStatus
  userAgent      String?            @map("user_agent") @db.Text
  referer        String?            @map("referer") @db.Text
  firstMessage   String?            @map("first_message") @db.Text
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  deletedAt      DateTime?          @map("deleted_at")

  conversations Conversation[]
  statusHistory LeadStatusHistory[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("leads")
}

model LeadStatusHistory {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId         String             @map("lead_id") @db.Uuid
  lead           Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStatus     LeadPipelineStatus? @map("from_status")
  toStatus       LeadPipelineStatus  @map("to_status")
  changedByUserId String            @map("changed_by_user_id") @db.Uuid
  changedBy      User               @relation(fields: [changedByUserId], references: [id], onDelete: Restrict)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([leadId, createdAt])
  @@map("lead_status_history")
}

model Conversation {
  id             String                   @id @default(uuid()) @db.Uuid
  organizationId String                   @map("organization_id") @db.Uuid
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assistantId    String                   @map("assistant_id") @db.Uuid
  assistant      Assistant                @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  leadId         String?                  @map("lead_id") @db.Uuid
  lead           Lead?                    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  agentId        String?                  @map("agent_id") @db.Uuid
  agent          Agent?                   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  status         ConversationThreadStatus
  source         ConversationSource
  createdByUserId String?                 @map("created_by_user_id") @db.Uuid
  createdBy      User?                    @relation("ConversationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  deletedAt      DateTime?                @map("deleted_at")
  /// Виджет: уже отправлено напоминание при молчании пользователя; сбрасывается при новом сообщении пользователя.
  widgetSilenceFollowUpSentAt DateTime?   @map("widget_silence_follow_up_sent_at")
  /// Виджет: сколько авто follow-up отправлено за текущую «тишину» (сброс при сообщении пользователя). Макс. см. WIDGET_MAX_FOLLOWUPS_PER_CONVERSATION.
  widgetFollowUpCount         Int         @default(0) @map("widget_follow_up_count")
  /// Sales hybrid FSM: greeting | qualification | offer | objection | close
  salesStage                  String      @default("greeting") @map("sales_stage")
  /// Hybrid sales memory (e.g. { "budget": 30000, "projectType": "landing" }).
  context                      Json?

  messages Message[]
  usages   Usage[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([leadId])
  @@index([assistantId])
  @@index([widgetSilenceFollowUpSentAt])
  @@index([widgetFollowUpCount])
  @@map("conversations")
}

model Message {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversationId String    @map("conversation_id") @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String    @db.Text
  tokens         Int       @default(0)
  executionId    String?   @map("execution_id") @db.Uuid
  execution      AgentExecution? @relation("ExecutionOutput", fields: [executionId], references: [id], onDelete: SetNull)
  triggeredExecutions AgentExecution[] @relation("ExecutionTrigger")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  @@index([organizationId])
  @@index([conversationId, createdAt])
  @@index([executionId])
  @@map("messages")
}

// --- Agent runtime ---

model AgentExecution {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentId        String    @map("agent_id") @db.Uuid
  agent          Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  initiatedByUserId String @map("initiated_by_user_id") @db.Uuid
  initiatedBy    User      @relation("ExecutionInitiator", fields: [initiatedByUserId], references: [id], onDelete: Restrict)
  status         String
  statusReason   String?   @map("status_reason")
  input          String    @db.Text
  output         String?   @db.Text
  stepsCount     Int       @default(0) @map("steps_count")
  toolCalls      Int       @default(0) @map("tool_calls")
  durationMs     Int?      @map("duration_ms")
  totalTokens    Int       @default(0) @map("total_tokens")
  metrics        Json?
  triggerMessageId String? @map("trigger_message_id") @db.Uuid
  triggerMessage Message?  @relation("ExecutionTrigger", fields: [triggerMessageId], references: [id], onDelete: SetNull)
  outputMessages Message[] @relation("ExecutionOutput")
  steps          AgentStep[]
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  @@index([organizationId])
  @@index([agentId])
  @@index([initiatedByUserId])
  @@index([triggerMessageId])
  @@map("agent_executions")
}

model AgentStep {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executionId    String         @map("execution_id") @db.Uuid
  execution      AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepIndex      Int            @map("step_index")
  type           String
  status         String
  payload        Json?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([executionId, stepIndex])
  @@map("agent_steps")
}

// --- RAG ---

model Knowledge {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assistantId    String    @map("assistant_id") @db.Uuid
  assistant      Assistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  type           String
  /// Original file name or ingested URL for display.
  sourceName     String?   @map("source_name")
  /// Intent label for hybrid sales routing.
  intent         String?   @map("intent")
  /// Ingest lifecycle: "processing" | "ready" | "failed"
  status         String    @default("ready")
  content        String    @db.Text
  embeddingId    String?   @map("embedding_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  chunks KnowledgeChunk[]

  @@index([organizationId])
  @@index([assistantId])
  @@map("knowledge")
}

model KnowledgeChunk {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  knowledgeId    String    @map("knowledge_id") @db.Uuid
  knowledge      Knowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  content        String    @db.Text
  embeddingId    String?   @map("embedding_id")
  embeddingModel String    @map("embedding_model")
  embeddingDim   Int       @map("embedding_dim")
  position       Int       @default(0)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([knowledgeId, position])
  @@map("knowledge_chunks")
}

// --- Metering ---

model Usage {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?   @map("user_id") @db.Uuid
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiKeyId       String?   @map("api_key_id") @db.Uuid
  apiKey         ApiKey?   @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  conversationId String?   @map("conversation_id") @db.Uuid
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  assistantId    String?   @map("assistant_id") @db.Uuid
  assistant      Assistant? @relation(fields: [assistantId], references: [id], onDelete: SetNull)
  model          String
  tokens         Int
  cost           Decimal?  @db.Decimal(12, 6)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([conversationId])
  @@index([assistantId])
  @@index([userId])
  @@map("usage")
}

/// Per API key hash — rate limiting (PostgreSQL row per key hash)
model RateLimitState {
  keyHash String   @id @map("key_hash")
  count   Int
  resetAt DateTime @map("reset_at")

  @@map("rate_limit_state")
}

/// One row per generated image (each variation is its own row)
model GeneratedImage {
  id             String   @id @default(uuid()) @db.Uuid
  jobId          String   @map("job_id")             /// BullMQ job / batch UUID
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  url            String
  localPath      String   @map("local_path")
  mode           String   @default("text")
  prompt         String   @db.Text
  originalPrompt String?  @map("original_prompt") @db.Text
  negativePrompt String?  @map("negative_prompt") @db.Text
  style          String?
  aspectRatio    String?  @map("aspect_ratio")
  width          Int      @default(1024)
  height         Int      @default(1024)
  variantIndex   Int      @default(0) @map("variant_index")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([jobId])
  @@map("generated_images")
}

/// Per-user image generation preferences / system prompt
model UserImageSettings {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  imageSystemPrompt String?  @map("image_system_prompt") @db.Text
  useSystemPrompt   Boolean  @default(false) @map("use_system_prompt")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("user_image_settings")
}
