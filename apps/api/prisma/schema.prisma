generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum LeadPipelineStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
  CLOSED
}

enum ConversationThreadStatus {
  OPEN
  ACTIVE
  ARCHIVED
  CLOSED
}

enum ConversationSource {
  WIDGET
  API
  DASHBOARD
}

enum UserRole {
  user
  admin
  root
}

// --- Core identity & tenancy ---

model User {
  id                   String    @id @default(uuid()) @db.Uuid
  email                String    @unique
  role                 UserRole  @default(user)
  passwordHash         String?   @map("password_hash")
  passwordResetToken   String?   @unique @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  memberships              Membership[]
  usages                   Usage[]
  initiatedAgentExecutions AgentExecution[]    @relation("ExecutionInitiator")
  leadStatusChanges        LeadStatusHistory[]
  conversationsCreated     Conversation[]      @relation("ConversationCreatedBy")
  adminAuditLogs           AdminAuditLog[]     @relation("AdminAuditActor")
  telegramBots             TelegramBot[]
  videoGenerationJobs      VideoGenerationJob[]
  agentConversationTakeovers AgentConversation[] @relation("AgentConversationTakeoverBy")

  @@map("users")
}

model AdminAuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  adminId   String   @map("admin_id") @db.Uuid
  admin     User     @relation("AdminAuditActor", fields: [adminId], references: [id], onDelete: Restrict)
  action    String
  entity    String
  entityId  String   @map("entity_id") @db.Uuid
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

model Plan {
  id                  String    @id @default(uuid()) @db.Uuid
  slug                String
  name                String
  maxRequestsPerMonth Int?      @map("max_requests_per_month")
  maxTokensPerMonth   Int?      @map("max_tokens_per_month")
  allowedModels       Json      @map("allowed_models")
  /// Cost in USD per 1 000 tokens. null = free / metered elsewhere.
  costPer1kTokens     Decimal?  @map("cost_per_1k_tokens") @db.Decimal(12, 6)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")

  organizations Organization[]

  @@index([slug])
  @@map("plans")
}

model Organization {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  slug         String    @unique
  planId       String    @map("plan_id") @db.Uuid
  plan         Plan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  requestsUsed Int       @default(0) @map("requests_used")
  tokensUsed   Int       @default(0) @map("tokens_used")
  resetAt      DateTime  @map("reset_at")
  isBlocked    Boolean   @default(false) @map("is_blocked")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  memberships       Membership[]
  apiKeys           ApiKey[]
  assistants        Assistant[]
  agents            Agent[]
  telegramBots      TelegramBot[]
  tools             Tool[]
  leads             Lead[]
  leadStatusHistory LeadStatusHistory[]
  conversations     Conversation[]
  avitoAccounts     AvitoAccount[]
  messages          Message[]
  agentExecutions   AgentExecution[]
  agentSteps        AgentStep[]
  knowledge             Knowledge[]
  knowledgeChunks       KnowledgeChunk[]
  usages                Usage[]
  notificationSettings  OrganizationNotificationSettings?
  followupTemplates     OrganizationFollowUpTemplate[]

  @@index([planId])
  @@map("organizations")
}

/// Per-organization notification settings (Telegram manager alerts + email).
/// Lives in DB (not env) so owners/admins can edit them from the admin panel.
model OrganizationNotificationSettings {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @unique @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Telegram Bot API token used to send manager alerts (may be empty → fallback to env LEAD_NOTIFY_TELEGRAM_BOT_TOKEN)
  tgManagerBotToken String?  @map("tg_manager_bot_token") @db.Text
  /// chat_id (user/group/channel) to deliver alerts to
  tgManagerChatId   String?  @map("tg_manager_chat_id")
  tgManagerEnabled  Boolean  @default(true) @map("tg_manager_enabled")

  /// Fire alert on first contact in a channel (Avito/Telegram/site)
  notifyOnNewLead  Boolean @default(true) @map("notify_on_new_lead")
  /// Fire alert when a lead hits HANDOFF (phone detected / contact request / stuck)
  notifyOnHandoff  Boolean @default(true) @map("notify_on_handoff")
  /// Fire alert when classifier marks the message as hot (buy intent, urgency…)
  notifyOnHotLead  Boolean @default(true) @map("notify_on_hot_lead")

  /// Optional email backup channel
  emailEnabled    Boolean @default(false) @map("email_enabled")
  /// Comma-separated list of recipients; SMTP creds still live in env
  emailRecipients String? @map("email_recipients") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("organization_notification_settings")
}

/// Per-organization follow-up message sequence (currently used by Avito pipeline).
/// If an organization has no active templates, the hard-coded defaults in
/// avito.followup.{queue,processor}.js still apply.
model OrganizationFollowUpTemplate {
  id             String @id @default(uuid()) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  /// Position in the ordered sequence (1-based).
  step         Int
  /// Delay from the last inbound user message, in minutes (1 .. 10080 == 1 week).
  delayMinutes Int     @map("delay_minutes")
  text         String  @db.Text
  isActive     Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt         @map("updated_at")

  @@unique([organizationId, step])
  @@index([organizationId, isActive])
  @@map("organization_followup_templates")
}

model Membership {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String         @map("organization_id") @db.Uuid
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           MembershipRole
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
  @@map("memberships")
}

model ApiKey {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assistantId    String?      @map("assistant_id") @db.Uuid
  assistant      Assistant?   @relation(fields: [assistantId], references: [id], onDelete: SetNull)
  keyHash        String       @unique @map("key_hash")
  name           String?
  /// Allowed origin hostnames (e.g. ["example.com","*.app.example.com"]). Empty = no restriction.
  allowedDomains String[]     @map("allowed_domains")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  usages Usage[]

  @@index([organizationId])
  @@index([assistantId])
  @@map("api_keys")
}

// --- AI resources (org-scoped) ---

model Assistant {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  model          String
  systemPrompt   String       @map("system_prompt") @db.Text
  settings       Json?
  /// Per-assistant overrides: intents, funnel, memory, validation. Falls back to defaultAssistantConfig if null.
  config         Json?
  /// Bumped on breaking prompt/model/RAG changes; conversations may record which version they started under.
  version        Int          @default(1)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  knowledges    Knowledge[]
  conversations Conversation[]
  agents        Agent[]
  apiKeys       ApiKey[]
  usages        Usage[]

  @@index([organizationId])
  @@map("assistants")
}

model Agent {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assistantId    String?       @map("assistant_id") @db.Uuid
  assistant      Assistant?    @relation(fields: [assistantId], references: [id], onDelete: SetNull)
  name           String
  type           String
  mode           String        @default("v1") @map("mode")
  /// Default LLM model for this agent's playground (overrides CHAT_MODEL env)
  model          String?
  /// Legacy flag — kept for backward compat; use avitoMode for fine-grained control
  autoReply      Boolean       @default(true) @map("auto_reply")
  /// Avito channel mode: "autoreply" | "copilot" | "human" | "off"
  /// autoreply  — AI generates + sends automatically
  /// copilot    — AI generates, saves to DB for human review (not sent)
  /// human      — saves message only, no AI
  /// off        — ignores all incoming Avito messages
  avitoMode      String        @default("autoreply") @map("avito_mode")
  /// FK to AvitoAccount — which Avito account handles this agent's chats
  avitoAccountId String?       @map("avito_account_id") @db.Uuid
  avitoAccount   AvitoAccount? @relation(fields: [avitoAccountId], references: [id], onDelete: SetNull)
  trigger        String?
  flow           Json?
  memory         Json?
  rules          String?       @db.Text
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  tools         Tool[]
  executions    AgentExecution[]
  conversations Conversation[]

  @@index([organizationId])
  @@index([assistantId])
  @@map("agents")
}

model Tool {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentId        String       @map("agent_id") @db.Uuid
  agent          Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  /// Stable handle per agent for planner, UI, and audits (unique with agentId).
  name           String       @default(cuid())
  type           String
  config         Json
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  @@unique([agentId, name])
  @@index([organizationId])
  @@index([agentId])
  @@map("tools")
}

// --- CRM ---

model Lead {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  source         String
  status         LeadPipelineStatus
  userAgent      String?            @map("user_agent") @db.Text
  referer        String?            @map("referer") @db.Text
  firstMessage   String?            @map("first_message") @db.Text
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  deletedAt      DateTime?          @map("deleted_at")

  conversations Conversation[]
  statusHistory LeadStatusHistory[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("leads")
}

model LeadStatusHistory {
  id              String              @id @default(uuid()) @db.Uuid
  organizationId  String              @map("organization_id") @db.Uuid
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leadId          String              @map("lead_id") @db.Uuid
  lead            Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStatus      LeadPipelineStatus? @map("from_status")
  toStatus        LeadPipelineStatus  @map("to_status")
  changedByUserId String              @map("changed_by_user_id") @db.Uuid
  changedBy       User                @relation(fields: [changedByUserId], references: [id], onDelete: Restrict)
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([leadId, createdAt])
  @@map("lead_status_history")
}

model Conversation {
  id                          String                   @id @default(uuid()) @db.Uuid
  organizationId              String                   @map("organization_id") @db.Uuid
  organization                Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assistantId                 String                   @map("assistant_id") @db.Uuid
  assistant                   Assistant                @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  leadId                      String?                  @map("lead_id") @db.Uuid
  lead                        Lead?                    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  agentId                     String?                  @map("agent_id") @db.Uuid
  agent                       Agent?                   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  status                      ConversationThreadStatus
  source                      ConversationSource
  createdByUserId             String?                  @map("created_by_user_id") @db.Uuid
  createdBy                   User?                    @relation("ConversationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt                   DateTime                 @default(now()) @map("created_at")
  updatedAt                   DateTime                 @updatedAt @map("updated_at")
  deletedAt                   DateTime?                @map("deleted_at")
  /// Виджет: уже отправлено напоминание при молчании пользователя; сбрасывается при новом сообщении пользователя.
  widgetSilenceFollowUpSentAt DateTime?                @map("widget_silence_follow_up_sent_at")
  /// Виджет: сколько авто follow-up отправлено за текущую «тишину» (сброс при сообщении пользователя). Макс. см. WIDGET_MAX_FOLLOWUPS_PER_CONVERSATION.
  widgetFollowUpCount         Int                      @default(0) @map("widget_follow_up_count")
  /// Sales hybrid FSM: greeting | qualification | offer | objection | close
  salesStage                  String                   @default("greeting") @map("sales_stage")
  /// Hybrid sales memory (e.g. { "budget": 30000, "projectType": "landing" }).
  context                     Json?

  messages Message[]
  usages   Usage[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([leadId])
  @@index([assistantId])
  @@index([widgetSilenceFollowUpSentAt])
  @@index([widgetFollowUpCount])
  @@map("conversations")
}

model Message {
  id                  String           @id @default(uuid()) @db.Uuid
  organizationId      String           @map("organization_id") @db.Uuid
  organization        Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversationId      String           @map("conversation_id") @db.Uuid
  conversation        Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role                String
  content             String           @db.Text
  tokens              Int              @default(0)
  executionId         String?          @map("execution_id") @db.Uuid
  execution           AgentExecution?  @relation("ExecutionOutput", fields: [executionId], references: [id], onDelete: SetNull)
  triggeredExecutions AgentExecution[] @relation("ExecutionTrigger")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  deletedAt           DateTime?        @map("deleted_at")

  @@index([organizationId])
  @@index([conversationId, createdAt])
  @@index([executionId])
  @@map("messages")
}

// --- Agent runtime ---

model AgentExecution {
  id                String       @id @default(uuid()) @db.Uuid
  organizationId    String       @map("organization_id") @db.Uuid
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentId           String       @map("agent_id") @db.Uuid
  agent             Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  initiatedByUserId String       @map("initiated_by_user_id") @db.Uuid
  initiatedBy       User         @relation("ExecutionInitiator", fields: [initiatedByUserId], references: [id], onDelete: Restrict)
  status            String
  statusReason      String?      @map("status_reason")
  input             String       @db.Text
  output            String?      @db.Text
  stepsCount        Int          @default(0) @map("steps_count")
  toolCalls         Int          @default(0) @map("tool_calls")
  durationMs        Int?         @map("duration_ms")
  totalTokens       Int          @default(0) @map("total_tokens")
  metrics           Json?
  triggerMessageId  String?      @map("trigger_message_id") @db.Uuid
  triggerMessage    Message?     @relation("ExecutionTrigger", fields: [triggerMessageId], references: [id], onDelete: SetNull)
  outputMessages    Message[]    @relation("ExecutionOutput")
  steps             AgentStep[]
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  deletedAt         DateTime?    @map("deleted_at")

  @@index([organizationId])
  @@index([agentId])
  @@index([initiatedByUserId])
  @@index([triggerMessageId])
  @@map("agent_executions")
}

model AgentStep {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executionId    String         @map("execution_id") @db.Uuid
  execution      AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepIndex      Int            @map("step_index")
  type           String
  status         String
  payload        Json?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([executionId, stepIndex])
  @@map("agent_steps")
}

// --- RAG ---

model Knowledge {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assistantId    String       @map("assistant_id") @db.Uuid
  assistant      Assistant    @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  type           String
  /// Original file name or ingested URL for display.
  sourceName     String?      @map("source_name")
  /// Intent label for hybrid sales routing.
  intent         String?      @map("intent")
  /// Ingest lifecycle: "processing" | "ready" | "failed"
  status         String       @default("ready")
  content        String       @db.Text
  embeddingId    String?      @map("embedding_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  chunks KnowledgeChunk[]

  @@index([organizationId])
  @@index([assistantId])
  @@map("knowledge")
}

model KnowledgeChunk {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  knowledgeId    String       @map("knowledge_id") @db.Uuid
  knowledge      Knowledge    @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  content        String       @db.Text
  embeddingId    String?      @map("embedding_id")
  embeddingModel String       @map("embedding_model")
  embeddingDim   Int          @map("embedding_dim")
  position       Int          @default(0)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([knowledgeId, position])
  @@map("knowledge_chunks")
}

// --- Metering ---

model Usage {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?       @map("user_id") @db.Uuid
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiKeyId       String?       @map("api_key_id") @db.Uuid
  apiKey         ApiKey?       @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  conversationId String?       @map("conversation_id") @db.Uuid
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  assistantId    String?       @map("assistant_id") @db.Uuid
  assistant      Assistant?    @relation(fields: [assistantId], references: [id], onDelete: SetNull)
  model          String
  tokens         Int
  cost           Decimal?      @db.Decimal(12, 6)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([conversationId])
  @@index([assistantId])
  @@index([userId])
  @@map("usage")
}

/// Avito account credentials per organisation (multi-tenant).
/// Replaces AVITO_TOKEN / AVITO_ACCOUNT_ID env vars.
model AvitoAccount {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Human-readable label (e.g. "Магазин запчастей")
  name           String?
  /// Avito OAuth bearer token
  accessToken    String       @map("access_token") @db.Text
  /// Optional Avito OAuth client_id for automatic token refresh
  clientId       String?      @map("client_id")
  /// Optional Avito OAuth client_secret for automatic token refresh
  clientSecret   String?      @map("client_secret") @db.Text
  /// Expiration time for accessToken (when obtained via client_credentials)
  accessTokenExpiresAt DateTime? @map("access_token_expires_at")
  /// Numeric Avito account / user ID (used for anti-loop and API calls)
  accountId      String       @map("account_id")
  /// Optional HMAC secret for webhook signature verification
  webhookSecret  String?      @map("webhook_secret")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  agents Agent[]

  @@index([organizationId])
  @@map("avito_accounts")
}

/// Avito webhook: one row per received event — used for idempotency
model AvitoWebhookEvent {
  id        String    @id /// Avito event_id (or generated hash)
  agentId   String    @map("agent_id") /// not a FK — stored as plain string
  type      String /// "message" | other Avito event types
  chatId    String?   @map("chat_id")
  authorId  String?   @map("author_id")
  payload   Json /// raw event body
  queuedAt  DateTime? @map("queued_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([agentId, createdAt])
  @@index([chatId])
  @@map("avito_webhook_events")
}

/// Avito: per-message audit trail — classifier + routing + AI output
model AvitoAuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  agentId        String   @map("agent_id") /// plain string — no FK constraint
  organizationId String   @map("organization_id") /// plain string — no FK constraint
  chatId         String   @map("chat_id")
  authorId       String   @map("author_id")
  conversationId String?  @map("conversation_id") /// plain string — no FK constraint
  eventId        String?  @map("event_id")
  /// Raw incoming text
  input          String   @db.Text
  /// AI-generated reply (null if mode=human/copilot not sent)
  output         String?  @db.Text
  /// Result of avito.classifier.js
  classification Json?
  /// Routing decision: "autoreply" | "copilot" | "human" | "skip"
  decision       String
  modelUsed      String?  @map("model_used")
  tokens         Int?
  durationMs     Int?     @map("duration_ms")
  success        Boolean  @default(true)
  error          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([agentId, createdAt])
  @@index([chatId])
  @@index([organizationId, createdAt])
  @@map("avito_audit_logs")
}

/// Avito follow-up sequence — scheduled re-engagement messages per chat
model AvitoFollowUp {
  id          String    @id @default(uuid())
  leadId      String    @map("lead_id") /// AvitoLead.id (plain string — no FK to allow flexibility)
  agentId     String    @map("agent_id")
  chatId      String    @map("chat_id")
  step        Int /// 1, 2 or 3
  status      String    @default("pending") /// pending | sent | cancelled
  scheduledAt DateTime  @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([leadId])
  @@index([agentId, chatId, status])
  @@index([scheduledAt, status])
  @@map("avito_follow_ups")
}

/// Avito sales FSM lead — tracks each unique Avito user through the sales funnel
model AvitoLead {
  id             String  @id @default(uuid())
  agentId        String  @map("agent_id")
  conversationId String  @map("conversation_id")
  chatId         String  @map("chat_id")
  externalUserId String? @map("external_user_id")

  /// FSM state: NEW | QUALIFYING | INTERESTED | HANDOFF | CLOSED | LOST
  status String @default("NEW")

  intent   String?
  priority String?
  isHot    Boolean @default(false) @map("is_hot")

  name   String?
  phone  String?
  budget Int?

  lastMessageAt DateTime @default(now()) @map("last_message_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([agentId, chatId])
  @@index([agentId, chatId])
  @@map("avito_leads")
}

/// Per API key hash — rate limiting (PostgreSQL row per key hash)
model RateLimitState {
  keyHash String   @id @map("key_hash")
  count   Int
  resetAt DateTime @map("reset_at")

  @@map("rate_limit_state")
}

/// One row per generated image (each variation is its own row)
model GeneratedImage {
  id             String   @id @default(uuid()) @db.Uuid
  jobId          String   @map("job_id") /// BullMQ job / batch UUID
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  url            String
  localPath      String   @map("local_path")
  mode           String   @default("text")
  prompt         String   @db.Text
  originalPrompt String?  @map("original_prompt") @db.Text
  negativePrompt String?  @map("negative_prompt") @db.Text
  style          String?
  aspectRatio    String?  @map("aspect_ratio")
  width          Int      @default(1024)
  height         Int      @default(1024)
  variantIndex   Int      @default(0) @map("variant_index")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([jobId])
  @@map("generated_images")
}

/// Execution record for each /image/generate call (brain+enhance+queue)
model PipelineExecution {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  jobId       String?   @map("job_id") /// primary BullMQ job id
  jobIds      Json?     @map("job_ids") /// all job ids (Json array, parallel variations)
  steps       Json /// pipelineExecution array
  status      String    @default("running") /// running | completed | failed
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  @@index([jobId])
  @@index([userId])
  @@map("pipeline_executions")
}

/// Agent playground: persistent multi-session conversations with full message history
model AgentConversation {
  id             String   @id @default(uuid()) @db.Uuid
  agentId        String   @map("agent_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  title          String?
  /// Channel origin: "web" (playground/API) | "avito" | future channels
  source         String   @default("web") @map("source")
  /// External channel conversation ID (e.g. Avito chat_id); null for web sessions
  externalId     String?  @map("external_id")
  /// External channel user identifier (e.g. Avito author_id)
  externalUserId String?  @map("external_user_id")
  /// JSON array of {role, content} messages (user + assistant turns, no system)
  messages       Json     @default("[]")

  /// Human takeover: when not null, AI stops replying on this conversation.
  /// Manager must explicitly release it to resume autoreplies.
  humanTakeoverAt   DateTime? @map("human_takeover_at")
  /// User who took over (FK users.id, ON DELETE SET NULL)
  humanTakeoverBy   String?   @map("human_takeover_by") @db.Uuid
  humanTakeoverByUser User?   @relation("AgentConversationTakeoverBy", fields: [humanTakeoverBy], references: [id], onDelete: SetNull)
  humanTakeoverNote String?   @map("human_takeover_note") @db.Text

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([agentId])
  @@index([userId])
  @@index([organizationId])
  @@index([source, externalId, agentId])
  @@index([humanTakeoverAt])
  @@map("agent_conversations")
}

/// Per-user image generation preferences / system prompt
model UserImageSettings {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  imageSystemPrompt String?  @map("image_system_prompt") @db.Text
  useSystemPrompt   Boolean  @default(false) @map("use_system_prompt")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("user_image_settings")
}

/// Telegram bot linked to a SaaS user (one bot per user)
model TelegramBot {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @unique @map("user_id") @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  botToken       String       @map("bot_token")
  botUsername    String?      @map("bot_username")
  webhookUrl          String?  @map("webhook_url")
  /// Секрет для заголовка X-Telegram-Bot-Api-Secret-Token (setWebhook secret_token)
  webhookSecretToken  String?  @map("webhook_secret_token") @db.Text
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")

  chats TelegramChat[]

  @@index([organizationId])
  @@map("telegram_bots")
}

model TelegramUser {
  id         String   @id @default(uuid()) @db.Uuid
  telegramId String   @unique @map("telegram_id")
  username   String?
  firstName  String?  @map("first_name")
  lastName   String?  @map("last_name")
  userId     String?  @map("user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("telegram_users")
}

/// One Telegram chat thread per bot + Telegram chat id (private/group)
model TelegramChat {
  id             String      @id @default(uuid()) @db.Uuid
  botId          String      @map("bot_id") @db.Uuid
  telegramChatId String      @map("telegram_chat_id")
  bot            TelegramBot @relation(fields: [botId], references: [id], onDelete: Cascade)
  userId         String      @map("user_id") @db.Uuid
  agentId        String?     @map("agent_id") @db.Uuid
  conversationId String?     @map("conversation_id") @db.Uuid
  /// Explicit UI mode: "chat" | "image" | "post" (no text-based intent guessing for chat/image).
  mode           String      @default("chat") @map("mode")
  /// Shown "image mode" UX banner count (max 2).
  uxHintImage    Int         @default(0) @map("ux_hint_image")
  /// Shown "chat mode" UX banner count (max 2).
  uxHintChat     Int         @default(0) @map("ux_hint_chat")
  /// Chat mode (sales): greeting | qualify | offer | close. Post mode: post_idle | post_waiting_topic | post_ready
  state          String      @default("greeting") @map("state")
  /// Черновик темы поста (пока ждём ответ «Нужна картинка?»)
  postDraftTopic String?     @map("post_draft_topic") @db.Text
  postDraftLinks Json?       @map("post_draft_links")
  /// SMM: sales | expert | story | ad
  postStyle      String?     @map("post_style")
  /// telegram | instagram | avito
  postPlatform   String?     @map("post_platform")
  /// friendly | aggressive | premium
  postTone       String?     @map("post_tone")
  /// Последние до 3 сгенерированных текстов поста (анти-дубликат)
  postLastGenerated Json?    @map("post_last_generated")
  createdAt      DateTime    @default(now()) @map("created_at")

  @@unique([botId, telegramChatId])
  @@index([userId])
  @@map("telegram_chats")
}

/// Асинхронная генерация видео (image + script + voice), статус: queued | processing | completed | failed
model VideoGenerationJob {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String   @map("organization_id") @db.Uuid
  status         String   @default("queued") @map("status")
  /// standard = legacy HTTP LTX / ffmpeg; ltx = ComfyUI GPU pipeline (+ interpolate, optional upscale)
  mode           String   @default("ltx") @map("mode")
  imageUrl       String   @map("image_url") @db.Text
  script         String   @db.Text
  voiceText      String?  @map("voice_text") @db.Text
  outputUrl      String?  @map("output_url") @db.Text
  error          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@map("video_generation_jobs")
}
