# Vision: POST /api/v1/product-photos/verify (Ollama must have this model pulled)
VISION_MODEL=llava:latest
# Optional limits (see docs/API_V1_PRODUCT_PHOTOS_VERIFY.md)
# PRODUCT_PHOTO_VERIFY_HOST_ALLOWLIST=cdn.example.com,img.example.com
# PRODUCT_PHOTO_VERIFY_DNS_CHECK=1
# PRODUCT_PHOTO_VERIFY_ALLOW_HTTP=0

# Stable Video Diffusion (GPU HTTP) — video worker
VIDEO_SVD_BASE_URL=http://188.124.55.89:5000
# Client timeouts (ms): POST /generate + download; default 300000 (5 min)
VIDEO_SVD_TIMEOUT_MS=300000
VIDEO_SVD_DOWNLOAD_TIMEOUT_MS=300000
VIDEO_SVD_HEALTH_TIMEOUT_MS=10000
# Retries after first failed SVD HTTP call (default 2 → 3 attempts total)
VIDEO_SVD_RETRIES=2
