# Install on server as: /etc/nginx/sites-available/ai-api
# Domain only: api.site-al.ru — does not modify other vhosts.

server {
    listen 80;
    server_name api.site-al.ru;

    location /api/ {
        proxy_pass http://127.0.0.1:4000/;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location = /widget.js {
        alias /var/www/ai-platform/apps/widget/widget.js;
        default_type application/javascript;
        add_header Cache-Control "public, max-age=3600";
    }

    location = / {
        default_type text/plain;
        return 200 "AI API RUNNING";
    }
}

# After certbot --nginx, HTTP→HTTPS redirect is usually added in this file or a separate ssl snippet.
